---
import { getCollection, type CollectionEntry } from 'astro:content';
import ProjectIframe from './ProjectIframe.astro';
import ChipList from './ChipList.astro';
import IconLink from './IconLink.astro';
import Button from './Button.astro';
import { GithubLogoIcon } from '@phosphor-icons/react';
import { formatDateRange } from '../lib/date';

type PetProjectEntry = CollectionEntry<'petProjects'>;

const entries: PetProjectEntry[] = await getCollection('petProjects');
const sortedEntries = entries.sort((a, b) => a.data.order - b.data.order);
const isHome = Astro.url.pathname === '/';

const HEADLINE_LABEL: string = 'Pet Projects';
const SEE_ALL_PROJECTS_TEXT: string = 'See all projects';

const GITHUB_LABEL: string = 'Github';
---

<section class='mm-pet-projects'>
  <h2 class='mm-pet-projects__headline'>{HEADLINE_LABEL}</h2>
  {
    isHome && (
      <Button class='mm-pet-projects__button' href='/about'>
        {SEE_ALL_PROJECTS_TEXT}
      </Button>
    )
  }
  <ul class='mm-pet-projects__content'>
    {
      sortedEntries.map((entry) => {
        const {
          heading,
          kicker,
          description,
          date,
          chips,
          githubUrl,
          preview,
        } = entry.data;

        return (
          <li class='mm-pet-project-item'>
            <span class='mm-pet-project-item__date'>{formatDateRange(date.from, date.to)}</span>
            <p class='mm-pet-project-item__kicker'>{kicker}</p>
            <h3 class='mm-pet-project-item__heading'>
              <a href={`/projects/${entry.id}`}>{heading}</a>
            </h3>
            <ChipList chips={chips} />
            <p class='mm-pet-project-item__preview'>{description}</p>
            <IconLink href={githubUrl} target='_blank'>
              {GITHUB_LABEL}
              <GithubLogoIcon slot='icon-left' />
            </IconLink>
            {preview && (
              <ProjectIframe src={preview.url} title={preview.title} />
            )}
            <hr class='mm-pet-project-item__divider' />
          </li>
        );
      })
    }
  </ul>
</section>
