---
type ProjectIFrameProps = {
  height?: string;
  src: string;
  title: string;
  width?: string;
};

const {
  height = "400px",
  width = "600px",
  src,
  title,
} = Astro.props as ProjectIFrameProps;

if (!src) throw new Error('ProjectIframe: "src" prop is required');
---

<div class="mm-iframe-wrapper">
  <button class="mm-iframe-wrapper__skip" type="button"
    >Skip project preview</button
  >
  <iframe
    src={src}
    width={width}
    height={height}
    style="border: 1px solid #ccc; border-radius: 4px;"
    title={title}
    allowfullscreen></iframe>
  <button class="mm-iframe-wrapper__skip mm-iframe-wrapper__skip--back" type="button"
    >Skip project preview (back)</button
  >
</div>

<script>
  const FOCUSABLE =
    'a[href], button:not([disabled]), input, select, textarea, [tabindex]:not([tabindex="-1"])';

  document
    .querySelectorAll<HTMLButtonElement>(".mm-iframe-wrapper__skip:not(.mm-iframe-wrapper__skip--back)")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const wrapper = btn.closest(".mm-iframe-wrapper");
        let el = wrapper?.nextElementSibling;
        while (el) {
          const target = el.matches(FOCUSABLE)
            ? el
            : el.querySelector<HTMLElement>(FOCUSABLE);
          if (target) {
            (target as HTMLElement).focus();
            return;
          }
          el = el.nextElementSibling;
        }
      });
    });

  document
    .querySelectorAll<HTMLButtonElement>(".mm-iframe-wrapper__skip--back")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const wrapper = btn.closest(".mm-iframe-wrapper");
        const getAllFocusable = (root: Element) =>
          Array.from(root.querySelectorAll<HTMLElement>(FOCUSABLE));

        let el = wrapper?.previousElementSibling;
        let lastTarget: HTMLElement | null = null;
        while (el) {
          const candidates = el.matches(FOCUSABLE)
            ? [el as HTMLElement]
            : getAllFocusable(el);
          if (candidates.length) lastTarget = candidates[candidates.length - 1];
          if (lastTarget) break;
          el = el.previousElementSibling;
        }
        lastTarget?.focus();
      });
    });
</script>
