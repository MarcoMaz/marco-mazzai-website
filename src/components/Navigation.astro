---
import { ListIcon, XIcon } from "@phosphor-icons/react";
import { getCollection, type CollectionEntry } from "astro:content";
import Avatar from "./Avatar.astro";

type NavigationEntry = CollectionEntry<"navigation">;

const navigationCollection: NavigationEntry[] =
  await getCollection("navigation");

if (navigationCollection.length === 0) {
  throw new Error("Navigation not found in copy collection");
}

const { navigationItems } = navigationCollection[0].data;

const pathname = Astro.url.pathname;
---

<!-- Hero Navigation: visible when hero is in view, fades out on scroll (desktop) -->
<div class="mm-navigation-hero">
  <!-- Mobile header: avatar + hamburger -->
  <div class="mm-navigation-hero__mobile">
    <Avatar />
    <button
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="mm-navigation-hero-list"
      class="mm-navigation-hero__hamburger"
    >
      <ListIcon
        size={24}
        aria-hidden={true}
        className="mm-navigation-hero__icon-list"
      />
      <XIcon
        size={24}
        aria-hidden={true}
        className="mm-navigation-hero__icon-x"
      />
    </button>
  </div>
  <!-- Nav list: collapsible on mobile, corner-positioned on desktop -->
  <ul id="mm-navigation-hero-list" class="mm-navigation-hero__list">
    {
      navigationItems.map(({ url, label }) => {
        const isActive =
          url === "/"
            ? pathname === "/"
            : url.startsWith("/") && pathname.startsWith(url);
        return (
          <li class="mm-navigation-hero__list-item">
            <a href={url} aria-current={isActive ? "page" : undefined}>
              {label}
            </a>
          </li>
        );
      })
    }
  </ul>
</div>

<!-- Side Navigation: offscreen left initially, slides in on scroll (desktop only) -->
<nav class="mm-navigation-side" aria-label="Site navigation">
  <Avatar />
  <ul class="mm-navigation-side__list">
    {
      navigationItems.map(({ url, label }) => {
        const isActive =
          url === "/"
            ? pathname === "/"
            : url.startsWith("/") && pathname.startsWith(url);
        return (
          <li class="mm-navigation-side__list-item">
            <a href={url} aria-current={isActive ? "page" : undefined}>
              {label}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<script>
  const MOBILE_MQ = window.matchMedia("(max-width: 1024px)");

  const button = document.querySelector<HTMLButtonElement>(
    ".mm-navigation-hero__hamburger",
  );
  const navList = document.getElementById("mm-navigation-hero-list");

  const setOpen = (open: boolean) => {
    if (!navList || !button) return;
    navList.style.display = open ? "flex" : MOBILE_MQ.matches ? "none" : "flex";
    button.setAttribute("aria-expanded", String(open));
    button.setAttribute(
      "aria-label",
      open ? "Close navigation" : "Open navigation",
    );
    document.body.classList.toggle("blocked", open);
  };

  if (navList) navList.style.display = MOBILE_MQ.matches ? "none" : "flex";

  button?.addEventListener("click", () => {
    setOpen(button.getAttribute("aria-expanded") !== "true");
  });

  window.addEventListener("resize", () => setOpen(false));
</script>
