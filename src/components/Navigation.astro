---
import { getCollection, type CollectionEntry } from 'astro:content';
import NavigationClient from './NavigationClient';

type NavigationEntry = CollectionEntry<'navigation'>;

const navigationCollection: NavigationEntry[] =
  await getCollection('navigation');

if (navigationCollection.length === 0) {
  throw new Error('Navigation not found in copy collection');
}

const { navigationItems } = navigationCollection[0].data;
---

<!-- Server-rendered desktop nav for immediate visibility -->
<!-- Client React component handles mobile hamburger and toggle -->
<NavigationClient client:load items={navigationItems} />


<nav class="Navigation__desktop">
  <ul id="nav-list">
    {
      navigationItems.map((navigationItem) => {
        const { url, label } = navigationItem;
        return (
          <li>
            <a href={url}>{label}</a>
          </li>
        );
      })
    }
  </ul>
</nav>

