---
import { PAGE_TITLES } from '../../content.config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChipList from '../../components/ChipList.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { formatDate } from '../../lib/date';

type BlogPost = CollectionEntry<'blog'>;

export const getStaticPaths: () => Promise<
  {
    params: { slug: string };
    props: { post: BlogPost; allPosts: BlogPost[] };
  }[]
> = async () => {
  const posts: BlogPost[] = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post, allPosts: posts },
  }));
};

const { post, allPosts } = Astro.props as {
  post: BlogPost;
  allPosts: BlogPost[];
};

const currentIndex: number = allPosts.findIndex((p) => p.id === post.id);
const prevPost: BlogPost | undefined = allPosts[currentIndex - 1];
const nextPost: BlogPost | undefined = allPosts[currentIndex + 1];

const { Content } = await render(post);

const blogSuffix = PAGE_TITLES.blogSuffix;
const { heading, kicker, date, chips } = post.data;
const pageTitle: string = `${heading} ${blogSuffix}`;
const formattedDate: string = formatDate(date);

const getReadingTime = (content: string, wordsPerMinute = 200): number => {
  const wordCount = content.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(wordCount / wordsPerMinute));
};
const readingTime: number = getReadingTime(post.body ?? '');

const { slug: prevSlug, heading: prevTitle }: { slug?: string; heading?: string } =
  prevPost?.data ?? {};
const { slug: nextSlug, heading: nextTitle }: { slug?: string; heading?: string } =
  nextPost?.data ?? {};
---

<BaseLayout title={pageTitle}>
  <section class='mm-blog-post'>
    <p class='mm-blog-post__kicker'>{kicker}</p>
    <h1>{heading}</h1>
    <div class='mm-blog-post__meta'>
      <span class='mm-blog-post__date'>{formattedDate}</span>
      <span class='mm-blog-post__reading-time'>{readingTime} min. read</span>
    </div>
    <ChipList chips={chips} />
    <article>
      <Content />
    </article>
    <nav>
      {prevSlug && <a href={`/blog/${prevSlug}`}>← {prevTitle}</a>}
      {nextSlug && <a href={`/blog/${nextSlug}`}>{nextTitle} →</a>}
    </nav>
  </section>
</BaseLayout>
