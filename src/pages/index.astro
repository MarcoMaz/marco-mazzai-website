---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import AboutSection from '../components/AboutSection.astro';
import BlogListSection from '../components/BlogListSection.astro';
import PetProjectsSection from '../components/PetProjectsSection.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

type HomeEntry = CollectionEntry<'home'>;

const homeCollection: HomeEntry[] = await getCollection('home');

if (homeCollection.length === 0) {
  throw new Error('Home page not found in copy collection');
}

const home: HomeEntry = homeCollection[0];

const {
  headline,
  kicker,
  summary,
  image: { alt, src },
} = home.data;

const { Content } = await render(home);
---

<BaseLayout>
  <section class='mm-hero'>
    <h1>{headline}</h1>
    <h2 set:html={kicker} />
    <p set:html={summary} />
    <Content />
    <img src={src} alt={alt} />
  </section>
  <BlogListSection showLink />
  <PetProjectsSection showLink />
  <AboutSection showLink />
</BaseLayout>
